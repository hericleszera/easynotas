# ─── Railway Environment Variables ───────────────────────────────────────────
# Cole estas variáveis no painel do Railway em: Settings > Variables

# Gerado automaticamente pelo Railway ao provisionar o PostgreSQL
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Chave secreta para assinar tokens JWT — use uma string longa e aleatória
JWT_SECRET=troque-por-uma-chave-secreta-longa-aqui

# Chave para proteger rotas de admin — use uma string longa e aleatória
ADMIN_KEY=troque-por-outra-chave-secreta-aqui

# Ambiente (deixe como production no Railway)
NODE_ENV=production