{
  "name": "easynotas",
  "version": "1.0.0",
  "description": "EasyNotas - Automação SEFAZ-AM DTE",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.easynotas.app",
    "productName": "EasyNotas",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "app/**",
      "node_modules/**"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.15.3",
    "puppeteer": "^25.3.0"
  }
}
